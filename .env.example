# Local model configuration (Ollama OpenAI-compatible endpoint)
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
LOCAL_MODEL=qwen3:4b

# Embedding model for vector search (pgvector)
# Dùng model embedding đã pull về: ollama list
EMBEDDING_MODEL=qllama/bge-small-en-v1.5:latest

# PostgreSQL Connection Configuration
# Thông tin kết nối PostgreSQL Vector Database

# Database host address (VD: localhost, 192.168.1.100, db.example.com)
POSTGRES_HOST=localhost

# Database port (mặc định 5432)
POSTGRES_PORT=5432

# Database name
POSTGRES_DB=server_products

# Database username
POSTGRES_USER=postgres

# Database password
POSTGRES_PASSWORD=your_password_here

# Table name containing products
POSTGRES_TABLE=products

# Table columns mapping (if different from default):
# Expected columns in table:
# - name: Tên sản phẩm
# - price: Giá sản phẩm
# - brand: Hãng sản phẩm (DELL, HPE, ASUS, SSN, etc.)
# - config: Cấu hình sản phẩm
# - description: Mô tả sản phẩm
# - embedding: Vector embedding (optional, for pgvector support)
